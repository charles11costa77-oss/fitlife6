name: Build AAB
on:
  push:
    branches: [main]
  workflow_dispatch:
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      - uses: actions/setup-node@v3
        with:
          node-version: 18
      - run: npm install -g @bubblewrap/cli
      - run: |
          mkdir -p twa
          cd twa
          bubblewrap init --manifest=https://melodious-sopapillas-b5d335.netlify.app/manifest.json
          bubblewrap build
      - uses: actions/upload-artifact@v3
        with:
          name: fitlife6-aab
          path: twa/app/build/outputs/bundle/release/*.aab
